   "source": [
    "# Determine R_L Score as presented in (Cameron & Windmeijer, 1995)\n",
    "# AI use statement: Google gemini was utilized to learn to analysis and explain the literature and providing insight on how to code for R_L\n",
    "\n",
    "# 1.  Actual data (y) and the  model's predictions (mu)\n",
    "y = y_cases\n",
    "mu = y_cases_predicted\n",
    "mu_null = np.mean(y_cases) # The constant-only model\n",
    "\n",
    "# 2. Calculating for KL Divergence (Table 1 in paper)\n",
    "def kl_divergence_exp(actual, predicted):\n",
    "    return -2 * np.sum(np.log(actual / predicted) + (actual - predicted) / predicted)\n",
    "\n",
    "# 3. Calculate K for exponential model and the null model\n",
    "k_model = kl_divergence_exp(y, mu)\n",
    "k_null = kl_divergence_exp(y, mu_null)\n",
    "\n",
    "# 4. Calculate R_L (the paper's R-squared)\n",
    "r_l = 1 - (k_model / k_null)\n",
    "\n",
    "print(f\"KL-based R-squared (R_L): {r_l:.4f}\")"
   ]
