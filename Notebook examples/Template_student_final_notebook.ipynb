    "# AI Usage statement: Google gemini was utilized to generate code to figure out how the code works, then code was modified according to pseudocode provided on Canvas based on new understanding.\n",
    "# First, import necessary libraries and tools for solcing the SEIR model.\n",
    "import pandas as pd\n",
