    "# Second, define variables necessary for the Euler method approximation of SEIR model. \n",
    "def SEIR(beta, gamma, sigma, S0, E0, I0, R0, timepoint, N):\n",
    "# Create empty lists/arrays for S, E, I, and R\n",
    "    S, E, I, R = []\n",
    "# Ensure that the first item of each list corresponds to initial values (S0, E0, I0, R0)\n",
    "    S[0], E[0], I[0], R[0]= S0, E0, I0, R0\n",
    "\n",
    "# Create a for loop that performs 4 iterations of the derivatives.\n",
    "    for timepoint in range(4):\n",
    "        dSdt = -(beta * S[timepoint] * I[timepoint]) / N\n",
    "        dEdt = (beta * S[timepoint] * I[timepoint]) / N - (sigma * E[timepoint])\n",
    "        dIdt = (sigma * E[timepoint]) - (gamma * I[timepoint])\n",
    "        dRdt = (gamma * I[timepoint])\n",
    "# Update list with successive values.\n",
    "        S[timepoint+1] = S[timepoint] + dSdt\n",
    "        E[timepoint+1] = E[timepoint] + dEdt\n",
    "        I[timepoint+1] = I[timepoint] + dIdt\n",
    "        R[timepoint+1] = R[timepoint] + dRdt\n",
    "# Return updated list for S, E, I, and R\n",
